# 本地开发模式（pnpm dev）共用生产数据目录
# 由 manage.sh 加载，也可复制到 src/apps/server/.env

NODE_ENV=development
PORT=3001
DATABASE_URL=/www/wwwroot/onyka/data/onyka.db
CORS_ORIGIN=http://127.0.0.1:5173
FRONTEND_URL=http://127.0.0.1:5173

# 若 JWT/加密密钥已存在于 data/ 目录，勿在此覆盖 JWT_SECRET / ENCRYPTION_KEY
# 首次纯本地开发且不共用 data 时，dev.js 会自动生成 apps/server/data
